local function getPlayerNames()
    local names = {}
    for _, v in pairs(Plrs:GetPlayers()) do
        if v.Name ~= lp.Name then table.insert(names, v.Name) end
    end
    if #names == 0 then table.insert(names, "Keine anderen Spieler") end
    return names
end

